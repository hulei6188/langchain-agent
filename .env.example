# Lingshu Agent custom agent platform

# Current: local API and frontend
API_HOST=127.0.0.1
API_PORT=8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Current: auth
JWT_SECRET=replace-with-a-long-random-secret
API_KEY_ENCRYPTION_KEY=
INVITE_API_ENABLED=false
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Current: local Docker infrastructure on this machine.
# Docker Compose exposes PostgreSQL on localhost:5433.
DATABASE_URL=postgresql+psycopg2://lingshu:lingshu@localhost:5433/lingshu_agent

# Current: OpenAI-compatible model provider protocol.
# Product default should prefer user-owned compatible configs, with Qwen/DashScope as the recommended preset.
# The OPENAI_* names are legacy env names for the compatible protocol, not a requirement to use GPT.
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
# Optional compatibility alias. If OPENAI_API_KEY is empty, the backend can use this key.
DASHSCOPE_API_KEY=
OPENAI_MODEL=qwen-plus
OPENAI_EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
RERANK_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_API_KEY=
HEALTH_MODEL_PROBE_ENABLED=true

# Optional backup chat provider. Keep OPENAI_API_BASE/OPENAI_MODEL on this provider
# only when you want global fallback chat to use DeepSeek.
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Local fallback for development without a model key.
LINGSHU_MOCK_LLM=false

# Current: local Milvus is the active vector target.
LINGSHU_VECTOR_BACKEND=milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=lingshu_chunks
MILVUS_DIMENSION=

# Current: RAG retrieval defaults. Agents and single chat turns can override part of these values.
RAG_TOP_K=4
RAG_DENSE_TOP_K=12
RAG_BM25_TOP_K=12
RAG_RRF_K=60
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=qwen3-rerank
RAG_RERANK_TOP_N=6
RAG_CACHE_ENABLED=true
RAG_CACHE_TTL_SECONDS=3600
RAG_REFUSE_WHEN_NO_EVIDENCE=true

# Current: no-key web search for the per-turn "联网搜索" switch and builtin_search tool.
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_TOP_K=5
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESPONSE_BYTES=524288
WEB_SEARCH_USER_AGENT=LingshuAgent/0.1 (+https://local.lingshu.agent)

# Current: upload limit for chat attachments and knowledge documents.
UPLOAD_MAX_BYTES=8388608

# Current: local Redis for task state/cache. Docker Compose exposes Redis on localhost:6380.
REDIS_URL=redis://localhost:6380/0

TAVILY_API_KEY=
SERPAPI_API_KEY=
